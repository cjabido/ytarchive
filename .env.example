# Docker Compose environment variables
# Copy this file to .env and edit as needed

# Port the API/backend is exposed on (default: 8000)
API_PORT=8000

# Port the frontend is exposed on (default: 3000)
FRONTEND_PORT=3000

# CORS origins allowed by the backend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost,safari-web-extension://
